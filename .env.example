# Copy to .env — or simply run scripts/deploy.ps1, which writes .env with the
# real values from the live deployment. .env is gitignored; the Keycloak
# client secret and admin password are sensitive.

# Entra / Azure identifiers
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-oidcfed
# Client ID of the user-assigned managed identity the federation targets.
AZURE_UAMI_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Your self-hosted OIDC provider
KEYCLOAK_URL=https://keycloak-oidcfed.<region>.azurecontainerapps.io
KEYCLOAK_REALM=azure
KEYCLOAK_CLIENT_ID=azure-federation
KEYCLOAK_CLIENT_SECRET=
# Test user provisioned in the realm (password-grant token federates to the
# same managed identity via a second federated identity credential).
KEYCLOAK_TEST_USERNAME=testuser
KEYCLOAK_TEST_USER_PASSWORD=
# Keycloak admin console password (bootstrap admin user 'admin').
KC_ADMIN_PASSWORD=
# PostgreSQL Flexible Server admin password (login 'keycloak').
POSTGRES_PASSWORD=

# Data-plane demo target (read by test-federation.ps1 and the Python sample)
DEMO_STORAGE_ACCOUNT=
DEMO_BLOB_CONTAINER=demo
DEMO_BLOB_NAME=hello.txt
